# ==================== 2. 配置参数 ====================
OUTPUT_ROOT = "./processed/OpenML"
RANDOM_SEED = 42
TEST_SIZE = 0.2
VAL_SIZE = 0.1
MAX_DATASETS = 5041  # 论文中提及的数据集总数
BATCH_SIZE = 100     # 批量请求大小，避免API超限
CACHE_DIR = "./openml_cache"
MISSING_THRESHOLD = 0.5

np.random.seed(RANDOM_SEED)

# 配置OpenML缓存目录
