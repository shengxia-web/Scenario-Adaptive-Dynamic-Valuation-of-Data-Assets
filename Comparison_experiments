# ============ 基线模型基类 ============
class BaseBaseline:
    """所有基线模型的统一接口"""
    def __init__(self, config: Dict[str, Any] = None):
        self.config = config or {}
        self.is_fitted = False

    def fit(self, train_data: Dict[str, Any]):
        """训练模型"""
        self.is_fitted = True
        return self

    def predict(self, test_data: Dict[str, Any]) -> np.ndarray:
        """预测返回价值数组"""
        raise NotImplementedError

    def evaluate(self, test_data: Dict[str, Any]) -> Dict[str, float]:
        """在测试数据上评估，返回MSE、MAE、R²等"""
        pred = self.predict(test_data)
        target = test_data['targets']
        metrics = Metrics()
        return {
            'mse': metrics.mse(pred, target),
            'mae': metrics.mae(pred, target),
            'rmse': metrics.rmse(pred, target),
            'r2': metrics.r2_score(pred, target),
            'direction_accuracy': metrics.direction_accuracy(pred, target)
        }


# ============ 传统基线 ============
class DCFBaseline(BaseBaseline):
    """传统折现现金流估值法：用线性回归拟合未来现金流折现"""
    def fit(self, train_data):
        # 假设特征中包含成本、收入等，这里简化使用所有数值特征进行线性回归
        X_train = train_data['node_features']
        y_train = train_data['targets']
        self.scaler = StandardScaler()
        X_scaled = self.scaler.fit_transform(X_train)
        self.model = LinearRegression()
        self.model.fit(X_scaled, y_train.ravel())
        self.is_fitted = True
        return self

    def predict(self, test_data):
        X_test = test_data['node_features']
        X_scaled = self.scaler.transform(X_test)
        return self.model.predict(X_scaled).reshape(-1, 1)


