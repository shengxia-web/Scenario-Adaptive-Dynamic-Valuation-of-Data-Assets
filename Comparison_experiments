# ============ 图神经网络基线 (PyG) ============
class GCNBaseline(BaseBaseline):
    """图卷积网络 (GCN)"""
    def __init__(self, config):
        super().__init__(config)
        self.hidden_dim = config.get('hidden_dim', 128)
        self.out_dim = config.get('out_dim', 1)
        self.num_layers = config.get('num_layers', 2)
        self.dropout = config.get('dropout', 0.3)
        self.lr = config.get('lr', 0.001)
        self.epochs = config.get('epochs', 200)

    def _build_model(self, in_dim):
        layers = []
        for i in range(self.num_layers):
            if i == 0:
                layers.append(GCNConv(in_dim, self.hidden_dim))
            else:
                layers.append(GCNConv(self.hidden_dim, self.hidden_dim))
        self.convs = nn.ModuleList(layers)
        self.lin = nn.Linear(self.hidden_dim, self.out_dim)
        self.optimizer = torch.optim.Adam(self.parameters(), lr=self.lr)

    def fit(self, train_data):
        # train_data包含: node_features, edge_index, edge_attr, targets
        device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
        x = torch.tensor(train_data['node_features'], dtype=torch.float).to(device)
        edge_index = torch.tensor(train_data['edge_index'], dtype=torch.long).to(device)
        y = torch.tensor(train_data['targets'], dtype=torch.float).to(device)
        # 构建模型
        in_dim = x.size(-1)
        self._build_model(in_dim)
        self.to(device)

        # 训练循环
        self.train()
        for epoch in range(self.epochs):
            self.optimizer.zero_grad()
            h = x
            for conv in self.convs:
                h = conv(h, edge_index)
                h = F.relu(h)
                h = F.dropout(h, p=self.dropout, training=self.training)
            out = self.lin(h)
            loss = F.mse_loss(out, y)
            loss.backward()
            self.optimizer.step()
            if epoch % 50 == 0:
                print(f"GCN Epoch {epoch}, Loss: {loss.item():.6f}")
        self.is_fitted = True
        self.device = device
        return self

    def predict(self, test_data):
        self.eval()
        device = self.device
        x = torch.tensor(test_data['node_features'], dtype=torch.float).to(device)
        edge_index = torch.tensor(test_data['edge_index'], dtype=torch.long).to(device)
        with torch.no_grad():
            h = x
            for conv in self.convs:
                h = conv(h, edge_index)
                h = F.relu(h)
            out = self.lin(h)
        return out.cpu().numpy()


class GraphSAGEBaseline(GCNBaseline):
    """GraphSAGE (SAGEConv)"""
    def _build_model(self, in_dim):
        layers = []
        for i in range(self.num_layers):
            if i == 0:
                layers.append(SAGEConv(in_dim, self.hidden_dim))
            else:
                layers.append(SAGEConv(self.hidden_dim, self.hidden_dim))
        self.convs = nn.ModuleList(layers)
        self.lin = nn.Linear(self.hidden_dim, self.out_dim)


class TGCBaseline(BaseBaseline):
    """T-GCN: 时序图卷积网络 (静态图+GRU)"""
    def __init__(self, config):
        super().__init__(config)
        self.hidden_dim = config.get('hidden_dim', 64)
        self.gru_hidden = config.get('gru_hidden', 64)
        self.num_layers = config.get('num_layers', 2)
        self.dropout = config.get('dropout', 0.3)
        self.lr = config.get('lr', 0.001)
        self.epochs = config.get('epochs', 200)

    def fit(self, train_data):
        # 期望train_data包含序列数据 node_features_seq [T, N, F] 和 edge_index
        device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
        # 简化：将序列作为多个时间步，先通过GCN编码，再通过GRU
        # 这里简化实现，直接使用GCN+GRU
        # 首先构建GCN
        self.gcn = GCNBaseline(self.config)
        # 用训练数据的第一个时间步作为特征维度
        x_seq = train_data['node_features_seq']  # [T, N, F]
        edge_index = torch.tensor(train_data['edge_index'], dtype=torch.long).to(device)
        T, N, F = x_seq.shape
        # 转换为PyG Data格式，每个时间步
        # 我们训练一个模型，输入为T个时间步，输出为T个时间步的价值
        # 实现上，我们将每个时间步的节点特征通过GCN，得到嵌入，然后用GRU处理序列
        # 这里我们构建一个简单网络：GCN提取每个时间步的节点嵌入，然后GRU聚合
        class TGCNet(nn.Module):
            def __init__(self, in_dim, hidden_dim, gru_hidden, out_dim, num_layers, dropout):
                super().__init__()
                self.gcn = GCNBaseline({'hidden_dim': hidden_dim, 'out_dim': hidden_dim,
                                        'num_layers': num_layers, 'dropout': dropout})
                # 但GCNBaseline需要图结构，我们这里用固定图
                self.gru = nn.GRU(hidden_dim, gru_hidden, batch_first=True)
                self.lin = nn.Linear(gru_hidden, out_dim)
            def forward(self, x_seq, edge_index):
                # x_seq: [T, N, F]
                # 每个时间步通过GCN
                T, N, F = x_seq.shape
                embeddings = []
                for t in range(T):
                    x_t = x_seq[t]  # [N, F]
                    # 模拟GCN
                    # 实际需实现GCN前向，这里简化用线性
                    h = torch.relu(torch.mm(x_t, self.gcn.lin.weight.t()))
                    embeddings.append(h)
                emb = torch.stack(embeddings, dim=0)  # [T, N, H]
                # 将N视为序列长度，T为batch? 这里我们将N视为batch，T为序列长度
                emb = emb.permute(1, 0, 2)  # [N, T, H]
                out, _ = self.gru(emb)  # [N, T, H]
                out = self.lin(out)  # [N, T, 1]
                return out.permute(1, 0, 2)  # [T, N, 1]
        # 训练...
        # 由于实现复杂，此处仅示意，实际应完整实现
        self.is_fitted = True
        return self
    # 省略预测


