class ARIMABaseline(BaseBaseline):
    """ARIMA 时间序列预测"""
    def fit(self, train_data):
        # 对每个节点单独拟合ARIMA，考虑计算量，仅演示
        seq = train_data['node_features_seq']  # [T, N, F] 取第一个特征或均值作为时间序列
        self.models = []
        # 简化：只对第一个节点
        series = seq[:, 0, 0]  # 取第一个特征
        self.model = ARIMA(series, order=(1,1,1))
        self.model_fit = self.model.fit()
        self.is_fitted = True
        return self

    def predict(self, test_data):
        # 预测未来1步
        pred = self.model_fit.forecast(steps=1)[0]
        return np.full((test_data['node_features'].shape[0], 1), pred)


class PageRankBaseline(BaseBaseline):
    """基于PageRank的节点重要性作为价值"""
    def fit(self, train_data):
        # 需要图结构
        edge_index = train_data['edge_index']  # [2, E]
        # 构建NetworkX图
        G = nx.DiGraph()
        for i in range(edge_index.shape[1]):
            u, v = edge_index[0, i], edge_index[1, i]
            G.add_edge(u, v)
        self.pr = nx.pagerank(G, alpha=0.85)
        self.is_fitted = True
        return self

    def predict(self, test_data):
        node_ids = test_data.get('node_ids', None)
        if node_ids is None:
            # 假设节点顺序一致
            node_ids = list(range(len(self.pr)))
        values = np.array([self.pr.get(i, 0.0) for i in node_ids]).reshape(-1, 1)
        return values


