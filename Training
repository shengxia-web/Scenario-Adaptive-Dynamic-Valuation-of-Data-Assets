class LearningRateScheduler:
    """
    余弦退火学习率调度器。
    从初始学习率衰减到最小学习率。
    """

    def __init__(self,
                 optimizer: optim.Optimizer,
                 initial_lr: float = 1e-3,
                 min_lr: float = 1e-5,
                 max_epochs: int = 500,
                 warmup_epochs: int = 0):
        """
        Args:
            optimizer: PyTorch优化器
            initial_lr: 初始学习率 (论文: 1e-3)
            min_lr: 最小学习率 (论文: 1e-5)
            max_epochs: 总训练轮数
            warmup_epochs: 预热轮数（默认0，不使用预热）
        """
        self.optimizer = optimizer
        self.initial_lr = initial_lr
        self.min_lr = min_lr
        self.max_epochs = max_epochs
        self.warmup_epochs = warmup_epochs
        self.current_epoch = 0

        # 使用PyTorch的CosineAnnealingLR
        self.scheduler = CosineAnnealingLR(
            optimizer,
            T_max=max_epochs - warmup_epochs,
            eta_min=min_lr
        )

    def step(self, epoch: Optional[int] = None):
        """更新学习率"""
        if epoch is not None:
            self.current_epoch = epoch
        else:
            self.current_epoch += 1

        if self.warmup_epochs > 0 and self.current_epoch <= self.warmup_epochs:
            # 线性预热
            warmup_factor = self.current_epoch / self.warmup_epochs
            lr = self.initial_lr * warmup_factor
            for param_group in self.optimizer.param_groups:
                param_group['lr'] = lr
        else:
            self.scheduler.step()

    def get_lr(self) -> float:
        """返回当前学习率"""
        return self.optimizer.param_groups[0]['lr']


class EarlyStopping:
    """
    早停机制：当验证损失连续patience个epoch没有改善时停止训练。
    """

    def __init__(self,
                 patience: int = 30,
                 min_delta: float = 1e-6,
                 mode: str = 'min'):
        """
        Args:
            patience: 容忍的epoch数（论文: 30）
            min_delta: 最小改善阈值
            mode: 'min' 表示损失越小越好，'max' 表示指标越大越好
        """
        self.patience = patience
        self.min_delta = min_delta
        self.mode = mode
        self.counter = 0
        self.best_score = None
        self.early_stop = False
        self.best_epoch = 0

    def __call__(self, val_loss: float, epoch: int) -> bool:
        """
        检查是否应该停止。
        Returns:
            bool: True表示应该停止
        """
        score = -val_loss if self.mode == 'min' else val_loss

        if self.best_score is None:
            self.best_score = score
            self.best_epoch = epoch
            self.counter = 0
            return False
        elif score > self.best_score + self.min_delta:
            # 改善
            self.best_score = score
            self.best_epoch = epoch
            self.counter = 0
            return False
        else:
            # 未改善
            self.counter += 1
            if self.counter >= self.patience:
                self.early_stop = True
                return True
            return False

    def should_stop(self) -> bool:
        """返回是否应该停止训练"""
        return self.early_stop


class Trainer:
    """
    完整训练器，管理模型训练、验证、检查点、早停等。
    """

    def __init__(self,
                 model: nn.Module,
                 device: torch.device,
                 config: Dict[str, Any]):
        """
        Args:
            model: 待训练的模型
            device: 训练设备 (cpu/cuda)
            config: 训练配置字典，包含:
                - initial_lr: 初始学习率 (默认1e-3)
                - min_lr: 最小学习率 (默认1e-5)
                - weight_decay: L2正则化系数 (默认1e-4)
                - max_epochs: 最大训练轮数 (默认500)
                - batch_size: 批次大小 (默认32)
                - patience: 早停耐心值 (默认30)
                - gradient_clip: 梯度裁剪阈值 (默认1.0)
                - checkpoint_dir: 检查点保存目录
                - log_interval: 日志输出间隔 (默认10)
        """
        self.model = model
        self.device = device
        self.config = config

        # 从配置中读取超参数
        self.initial_lr = config.get('initial_lr', 1e-3)
        self.min_lr = config.get('min_lr', 1e-5)
        self.weight_decay = config.get('weight_decay', 1e-4)
        self.max_epochs = config.get('max_epochs', 500)
        self.batch_size = config.get('batch_size', 32)
        self.patience = config.get('patience', 30)
        self.gradient_clip = config.get('gradient_clip', 1.0)
        self.checkpoint_dir = config.get('checkpoint_dir', './checkpoints')
        self.log_interval = config.get('log_interval', 10)

        # 创建检查点目录
        os.makedirs(self.checkpoint_dir, exist_ok=True)

        # 设置优化器和调度器
        self.optimizer = None
        self.scheduler = None
        self.early_stopping = None

        # 训练历史记录
        self.history = {
            'train_loss': [],
            'val_loss': [],
            'train_metrics': [],
            'val_metrics': [],
            'lr': []
        }
        self.best_val_loss = float('inf')
        self.best_epoch = 0

    def _initialize_optimizer(self):
        """初始化Adam优化器"""
        self.optimizer = optim.Adam(
            self.model.parameters(),
            lr=self.initial_lr,
            weight_decay=self.weight_decay,
            betas=(0.9, 0.999)
        )

    def _initialize_scheduler(self):
        """初始化余弦退火调度器"""
        self.scheduler = LearningRateScheduler(
            optimizer=self.optimizer,
            initial_lr=self.initial_lr,
            min_lr=self.min_lr,
            max_epochs=self.max_epochs
        )

    def _initialize_early_stopping(self):
        """初始化早停"""
        self.early_stopping = EarlyStopping(
            patience=self.patience,
            min_delta=1e-6,
            mode='min'
        )

    def _get_loss_function(self):
        """根据配置获取损失函数，使用CombinedLoss"""
        from loss_functions import CombinedLosses  # 假设模块8在相同路径
        return CombinedLosses(
            lambda_temporal=self.config.get('lambda_temporal', 0.1),
            lambda_reg=self.config.get('lambda_reg', 1e-4),
            use_mae=False,
            temporal_type='mse'
        )

    def train_epoch(self,
                    dataloader: DataLoader,
                    epoch: int) -> Dict[str, float]:
        """
        单个训练epoch。

        Returns:
            包含平均损失和指标的字典
        """
        self.model.train()
        total_loss = 0.0
        total_metrics = {}
        num_batches = 0

        for batch_idx, batch_data in enumerate(dataloader):
            # 假设batch_data包含:
            #   node_features, edge_index, edge_attr, scenario_params, env_params, targets
            # 具体根据数据加载器实现调整
            node_features = batch_data['node_features'].to(self.device)
            edge_index = batch_data['edge_index'].to(self.device)
            edge_attr = batch_data['edge_attr'].to(self.device)
            scenario_params = batch_data.get('scenario_params')
            env_params = batch_data.get('env_params')
            targets = batch_data['targets'].to(self.device)

            if scenario_params is not None:
                scenario_params = scenario_params.to(self.device)
            if env_params is not None:
                env_params = env_params.to(self.device)

            # 前向传播
            outputs = self.model(
                node_features,
                edge_index,
                edge_attr,
                scenario_params,
                env_params,
                time_steps=1,
                return_attention=False
            )
            predictions = outputs['values']  # [batch, N, 1]

            # 计算损失
            # 使用联合损失（包含时序损失需要序列，此处仅单步，故时序部分为0）
            loss_fn = self._get_loss_function()
            loss = loss_fn.total_loss(
                predictions,
                targets,
                model_parameters=self.model.parameters(),
                pred_seq=None,
                target_seq=None,
                return_components=False
            )

            # 反向传播
            self.optimizer.zero_grad()
            loss.backward()

            # 梯度裁剪
            if self.gradient_clip > 0:
                torch.nn.utils.clip_grad_norm_(
                    self.model.parameters(),
                    self.gradient_clip
                )

            self.optimizer.step()

            # 累积损失
            total_loss += loss.item()
            num_batches += 1

            # 日志输出
            if batch_idx % self.log_interval == 0:
                print(f"Epoch {epoch+1}/{self.max_epochs}, Batch {batch_idx}/{len(dataloader)}, Loss: {loss.item():.6f}")

        avg_loss = total_loss / num_batches
        self.history['train_loss'].append(avg_loss)

        return {'loss': avg_loss}

    def validate(self,
                 dataloader: DataLoader) -> Dict[str, float]:
        """
        验证/评估循环。

        Returns:
            验证集平均损失和指标
        """
        self.model.eval()
        total_loss = 0.0
        num_batches = 0

        with torch.no_grad():
            for batch_data in dataloader:
                node_features = batch_data['node_features'].to(self.device)
                edge_index = batch_data['edge_index'].to(self.device)
                edge_attr = batch_data['edge_attr'].to(self.device)
                scenario_params = batch_data.get('scenario_params')
                env_params = batch_data.get('env_params')
                targets = batch_data['targets'].to(self.device)

                if scenario_params is not None:
                    scenario_params = scenario_params.to(self.device)
                if env_params is not None:
                    env_params = env_params.to(self.device)

                outputs = self.model(
                    node_features,
                    edge_index,
                    edge_attr,
                    scenario_params,
                    env_params,
                    time_steps=1,
                    return_attention=False
                )
                predictions = outputs['values']

                # 计算损失（此处用MSE）
                loss = nn.functional.mse_loss(predictions, targets)
                total_loss += loss.item()
                num_batches += 1

        avg_loss = total_loss / num_batches
        self.history['val_loss'].append(avg_loss)

        return {'loss': avg_loss}

    def train(self,
              train_dataloader: DataLoader,
              val_dataloader: Optional[DataLoader] = None,
              test_dataloader: Optional[DataLoader] = None) -> Dict[str, Any]:
        """
        完整训练流程。

        Args:
            train_dataloader: 训练数据加载器
            val_dataloader: 验证数据加载器（可选，用于早停和模型选择）
            test_dataloader: 测试数据加载器（可选，最终评估）

        Returns:
            包含训练历史、最佳模型状态等的字典
        """
        # 初始化优化器、调度器、早停
        self._initialize_optimizer()
        self._initialize_scheduler()
        self._initialize_early_stopping()

        print(f"开始训练，设备: {self.device}")
        print(f"初始学习率: {self.initial_lr}, 最小学习率: {self.min_lr}")
        print(f"权重衰减: {self.weight_decay}, 梯度裁剪: {self.gradient_clip}")
        print(f"早停耐心: {self.patience}, 最大轮数: {self.max_epochs}")

        start_time = time.time()
        best_model_state = None

        for epoch in range(self.max_epochs):
            # 训练一个epoch
            train_metrics = self.train_epoch(train_dataloader, epoch)
            train_loss = train_metrics['loss']

            # 验证（如果提供验证集）
            if val_dataloader is not None:
                val_metrics = self.validate(val_dataloader)
                val_loss = val_metrics['loss']
                print(f"Epoch {epoch+1}/{self.max_epochs}, Train Loss: {train_loss:.6f}, Val Loss: {val_loss:.6f}")
            else:
                val_loss = train_loss
                print(f"Epoch {epoch+1}/{self.max_epochs}, Train Loss: {train_loss:.6f}")

            # 记录学习率
            current_lr = self.scheduler.get_lr()
            self.history['lr'].append(current_lr)

            # 更新调度器
            self.scheduler.step()

            # 早停检查
            if val_dataloader is not None:
                if self.early_stopping(val_loss, epoch):
                    print(f"早停触发于 epoch {epoch+1}")
                    break

            # 保存最佳模型
            if val_loss < self.best_val_loss:
                self.best_val_loss = val_loss
                self.best_epoch = epoch
                best_model_state = {
                    'epoch': epoch,
                    'model_state_dict': self.model.state_dict(),
                    'optimizer_state_dict': self.optimizer.state_dict(),
                    'val_loss': val_loss,
                    'config': self.config
                }
                # 保存检查点
                self.save_checkpoint(best_model_state, is_best=True)

        # 训练结束
        end_time = time.time()
        training_time = end_time - start_time
        print(f"\n训练完成！总用时: {training_time:.2f} 秒")
        print(f"最佳验证损失: {self.best_val_loss:.6f} (epoch {self.best_epoch+1})")

        # 加载最佳模型用于测试
        if best_model_state is not None:
            self.model.load_state_dict(best_model_state['model_state_dict'])

        # 如果有测试集，进行评估
        test_metrics = None
        if test_dataloader is not None:
            print("\n在测试集上评估最佳模型...")
            test_metrics = self.validate(test_dataloader)
            print(f"测试损失: {test_metrics['loss']:.6f}")

        # 返回结果
        return {
            'history': self.history,
            'best_val_loss': self.best_val_loss,
            'best_epoch': self.best_epoch,
            'training_time': training_time,
            'test_metrics': test_metrics,
            'best_model_state': best_model_state
        }

    def save_checkpoint(self,
                        state: Dict[str, Any],
                        is_best: bool = True,
                        filename: str = 'checkpoint.pt'):
        """
        保存模型检查点。
        """
        if is_best:
            filepath = os.path.join(self.checkpoint_dir, 'best_model.pt')
        else:
            filepath = os.path.join(self.checkpoint_dir, filename)

        # 确保state包含必要的字段
        if 'model_state_dict' not in state:
            state['model_state_dict'] = self.model.state_dict()
        if 'optimizer_state_dict' not in state:
            state['optimizer_state_dict'] = self.optimizer.state_dict()
        if 'epoch' not in state:
            state['epoch'] = self.best_epoch
        if 'val_loss' not in state:
            state['val_loss'] = self.best_val_loss

        torch.save(state, filepath)
        print(f"检查点已保存至: {filepath}")

    def load_checkpoint(self,
                        checkpoint_path: str,
                        load_optimizer: bool = False) -> Dict[str, Any]:
        """
        加载模型检查点。
        """
        if not os.path.exists(checkpoint_path):
            raise FileNotFoundError(f"检查点文件不存在: {checkpoint_path}")

        checkpoint = torch.load(checkpoint_path, map_location=self.device)

        # 加载模型参数
        self.model.load_state_dict(checkpoint['model_state_dict'])
        print(f"已加载模型参数从: {checkpoint_path}")

        # 加载优化器状态
        if load_optimizer and 'optimizer_state_dict' in checkpoint:
            if self.optimizer is None:
                self._initialize_optimizer()
            self.optimizer.load_state_dict(checkpoint['optimizer_state_dict'])
            print("已加载优化器状态")

        return checkpoint


