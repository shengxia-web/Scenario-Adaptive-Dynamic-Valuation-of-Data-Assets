    # 创建模型
    model = ScenarioAdaptiveValuationModel(
        node_feature_dim=node_feature_dim,
        gat_hidden_dim=gat_hidden_dim,
        gat_heads=gat_heads,
        gat_layers=gat_layers,
        gat_dropout=gat_dropout,
        gru_hidden_dim=gru_hidden_dim,
        context_embed_dim=context_embed_dim,
        scenario_feature_dim=scenario_feature_dim,
        env_feature_dim=env_feature_dim,
        value_hidden_dims=[64, 32],
        use_context=True,
        use_attention_in_context=True
    )

    # 生成示例输入
    num_nodes = 50
    num_edges = 200
    batch_size = 4  # 批次大小

    node_features = torch.randn(batch_size, num_nodes, node_feature_dim)
    edge_index = torch.randint(0, num_nodes, (2, num_edges), dtype=torch.long)
    edge_attr = torch.rand(num_edges, 1)  # 边权重
    scenario_params = torch.randn(batch_size, scenario_feature_dim)
    env_params = torch.randn(batch_size, env_feature_dim)

    # 前向传播
    outputs = model(
        node_features,
        edge_index,
        edge_attr,
        scenario_params,
        env_params,
        time_steps=1,
        return_attention=True
    )

    print("预测价值形状:", outputs['values'].shape)  # [4, 50, 1]
    print("注意力权重形状:", outputs['attention_weights'].shape)  # [4, 50, 5]
    print("上下文嵌入形状:", outputs['context_embedding'].shape)  # [4, 32]

    # 训练损失计算
    targets = torch.randn(batch_size, num_nodes, 1)
    loss = model.loss_backward(outputs['values'], targets, 'mse')
    print("损失值:", loss.item())

    print("\n集成模型测试完成。")
